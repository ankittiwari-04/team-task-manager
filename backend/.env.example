# ─────────────────────────────────────────────────────────
# Database — PostgreSQL connection string
# Local example: postgresql://postgres:password@localhost:5432/taskmgr
# Railway: copy from the PostgreSQL service "Connect" tab
# ─────────────────────────────────────────────────────────
DATABASE_URL=postgresql://user:password@localhost:5432/taskmgr

# ─────────────────────────────────────────────────────────
# JWT Secrets — generate with: openssl rand -hex 64
# Both must be at least 64 characters in production
# ─────────────────────────────────────────────────────────
JWT_SECRET=change-this-to-a-random-64-char-string-in-production
JWT_REFRESH_SECRET=change-this-to-a-different-random-64-char-string

# ─────────────────────────────────────────────────────────
# Server
# ─────────────────────────────────────────────────────────
PORT=5000
NODE_ENV=development

# ─────────────────────────────────────────────────────────
# Frontend URL — used for CORS origin whitelist
# Production: set to your Vercel deployment URL
# ─────────────────────────────────────────────────────────
FRONTEND_URL=http://localhost:5173
